<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="lmsPU" transaction-type="JTA">

        <jta-data-source>jdbc/lms</jta-data-source>

        <class>com.company.lms.model.Role</class>
        <class>com.company.lms.model.Employee</class>
        <class>com.company.lms.model.LeaveRequest</class>
        <class>com.company.lms.model.AuditLog</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <property name="eclipselink.logging.level" value="FINE"/>
        </properties>

    </persistence-unit>

</persistence>